# ─── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=genera-una-key-segura-aqui
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Base de datos ────────────────────────────────────────────────────────────
# En desarrollo local: dejar vacío o no incluir → usa SQLite automáticamente
# En producción: pegar la connection string de Supabase
# La sacás de: Supabase Dashboard → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ─── Mercado Pago ─────────────────────────────────────────────────────────────
MP_ACCESS_TOKEN=TEST-...
MP_APP_ID=
MP_CLIENT_SECRET=
MP_WEBHOOK_SECRET=
MP_REDIRECT_URI=http://localhost:8000/api/boliches/mp/callback/

# ─── Fees (no editar en producción sin consenso) ──────────────────────────────
FEE_MP_PCT=5.99
NORWARE_FEE_PCT=8.0

# ─── Mail (SMTP) ─────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=SG.xxx
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@norware.com

# ─── URLs ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
